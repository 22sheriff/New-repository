# Copy this to .env and fill in your values
# On Railway: set these in the Environment tab (not in a file)

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/matola_db

# Optional: restrict CORS to your Netlify URL once deployed
# ALLOWED_ORIGINS=https://your-site.netlify.app
